                  { "key": "Authorization", "value": "Bearer {{authToken}}" },
                  { "key": "x-tenant-id", "value": "{{tenantId}}" }
                ],
                "url": {
                  "raw": "{{baseUrl}}/api/v1/artists/?page=1&pageSize=20",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "artists", ""],
                  "query": [{ "key": "page", "value": "1" }, { "key": "pageSize", "value": "20" }]
                }
              }
