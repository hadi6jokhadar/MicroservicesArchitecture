{
  "info": {
    "_postman_id": "filemanager-service-collection",
    "name": "FileManager Service API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5005", "type": "string" },
    { "key": "tenantId", "value": "your-tenant-id", "type": "string" },
    { "key": "authToken", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "serviceSecret", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Public",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
          }
        },
        {
          "name": "Health Readiness",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/health/ready", "host": ["{{baseUrl}}"], "path": ["health", "ready"] }
          }
        },
        {
          "name": "Download File",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/filemanager/files/:id/download", "host": ["{{baseUrl}}"], "path": ["api", "filemanager", "files", ":id", "download"], "variable": [{ "key": "id", "value": "1" }] }
          }
        }
      ]
    },
    {
      "name": "Authenticated",
      "item": [
        {
          "name": "Upload File",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "x-tenant-id", "value": "{{tenantId}}", "description": "Optional" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": "" },
                { "key": "category", "value": "documents", "type": "text" }
              ]
            },
            "url": { "raw": "{{baseUrl}}/api/filemanager/files", "host": ["{{baseUrl}}"], "path": ["api", "filemanager", "files"] }
          }
        },
        {
          "name": "Get File by ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "x-tenant-id", "value": "{{tenantId}}", "description": "Optional" }
            ],
            "url": { "raw": "{{baseUrl}}/api/filemanager/files/:id", "host": ["{{baseUrl}}"], "path": ["api", "filemanager", "files", ":id"], "variable": [{ "key": "id", "value": "1" }] }
          }
        },
        {
          "name": "Get Files List",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "x-tenant-id", "value": "{{tenantId}}", "description": "Optional" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/filemanager/files?page=1&pageSize=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "filemanager", "files"],
              "query": [{ "key": "page", "value": "1" }, { "key": "pageSize", "value": "20" }]
            }
          }
        },
        {
          "name": "Update File Metadata",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-tenant-id", "value": "{{tenantId}}", "description": "Optional" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"updated-filename\",\n  \"category\": \"images\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/filemanager/files/:id", "host": ["{{baseUrl}}"], "path": ["api", "filemanager", "files", ":id"], "variable": [{ "key": "id", "value": "1" }] }
          }
        },
        {
          "name": "Delete File",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "x-tenant-id", "value": "{{tenantId}}", "description": "Optional" }
            ],
            "url": { "raw": "{{baseUrl}}/api/filemanager/files/:id", "host": ["{{baseUrl}}"], "path": ["api", "filemanager", "files", ":id"], "variable": [{ "key": "id", "value": "1" }] }
          }
        },
        {
          "name": "Upload File to Blob",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "x-tenant-id", "value": "{{tenantId}}", "description": "Optional" }
            ],
            "url": { "raw": "{{baseUrl}}/api/filemanager/files/:id/upload-to-blob", "host": ["{{baseUrl}}"], "path": ["api", "filemanager", "files", ":id", "upload-to-blob"], "variable": [{ "key": "id", "value": "1" }] }
          }
        },
        {
          "name": "Remove File from Blob",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "x-tenant-id", "value": "{{tenantId}}", "description": "Optional" }
            ],
            "url": { "raw": "{{baseUrl}}/api/filemanager/files/:id/remove-from-blob", "host": ["{{baseUrl}}"], "path": ["api", "filemanager", "files", ":id", "remove-from-blob"], "variable": [{ "key": "id", "value": "1" }] }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Delete File (Admin)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/filemanager/admin/files/:id?tenantId={{tenantId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "filemanager", "admin", "files", ":id"],
              "query": [{ "key": "tenantId", "value": "{{tenantId}}", "description": "Optional" }],
              "variable": [{ "key": "id", "value": "1" }]
            }
          }
        },
        {
          "name": "Delete All Temp Files",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/filemanager/admin/files/temp/all", "host": ["{{baseUrl}}"], "path": ["api", "filemanager", "admin", "files", "temp", "all"] }
          }
        },
        {
          "name": "Delete Old Temp Files",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/filemanager/admin/files/temp/old?olderThanDays=7",
              "host": ["{{baseUrl}}"],
              "path": ["api", "filemanager", "admin", "files", "temp", "old"],
              "query": [{ "key": "olderThanDays", "value": "7" }]
            }
          }
        },
        {
          "name": "Upload File to Blob (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/filemanager/admin/files/:id/upload-to-blob?tenantId={{tenantId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "filemanager", "admin", "files", ":id", "upload-to-blob"],
              "query": [{ "key": "tenantId", "value": "{{tenantId}}", "description": "Optional" }],
              "variable": [{ "key": "id", "value": "1" }]
            }
          }
        },
        {
          "name": "Remove File from Blob (Admin)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/filemanager/admin/files/:id/remove-from-blob?tenantId={{tenantId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "filemanager", "admin", "files", ":id", "remove-from-blob"],
              "query": [{ "key": "tenantId", "value": "{{tenantId}}", "description": "Optional" }],
              "variable": [{ "key": "id", "value": "1" }]
            }
          }
        }
      ]
    },
    {
      "name": "Internal",
      "item": [
        {
          "name": "Get File by ID (Internal)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Service-Secret", "value": "{{serviceSecret}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/filemanager/internal/files/:id?tenantId={{tenantId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "filemanager", "internal", "files", ":id"],
              "query": [{ "key": "tenantId", "value": "{{tenantId}}", "description": "Optional" }],
              "variable": [{ "key": "id", "value": "1" }]
            }
          }
        },
        {
          "name": "Get Files by IDs (Internal Batch)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Service-Secret", "value": "{{serviceSecret}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/filemanager/internal/files/batch?tenantId={{tenantId}}&fileIds=1&fileIds=2&fileIds=3",
              "host": ["{{baseUrl}}"],
              "path": ["api", "filemanager", "internal", "files", "batch"],
              "query": [
                { "key": "tenantId", "value": "{{tenantId}}", "description": "Optional" },
                { "key": "fileIds", "value": "1" },
                { "key": "fileIds", "value": "2" },
                { "key": "fileIds", "value": "3" }
              ]
            }
          }
        },
        {
          "name": "Change File Temp Status (Internal)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "X-Service-Secret", "value": "{{serviceSecret}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/filemanager/internal/files/:id/temp-status?usageArea=Nasheed&rowId=42&isNew=true&tenantId={{tenantId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "filemanager", "internal", "files", ":id", "temp-status"],
              "query": [
                { "key": "usageArea", "value": "Nasheed" },
                { "key": "rowId", "value": "42" },
                { "key": "isNew", "value": "true" },
                { "key": "tenantId", "value": "{{tenantId}}", "description": "Optional" }
              ],
              "variable": [{ "key": "id", "value": "1" }]
            }
          }
        }
      ]
    }
  ]
}
