              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/filemanager/admin/files?pageNumber=1&pageSize=10&tenantId={{tenantId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "filemanager", "admin", "files"],
              "query": [
                {
                  "key": "pageNumber",
                  "value": "1"
                },
                {
                  "key": "pageSize",
                  "value": "10"
                },
                {
                  "key": "tenantId",
                  "value": "{{tenantId}}"
                }
              ]
            }
          }
        },
        {
          "name": "Update File Metadata (Global)",
          "request": {
            "method": "PUT",
            "header": [
