                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/filemanager/admin/files/temp/old?olderThanDays=7",
              "host": ["{{baseUrl}}"],
              "path": ["api", "filemanager", "admin", "files", "temp", "old"],
              "query": [
                {
                  "key": "olderThanDays",
                  "value": "7"
                }
              ]
            }
          }
