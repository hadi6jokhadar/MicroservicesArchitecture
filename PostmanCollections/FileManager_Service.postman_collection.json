{
  "info": {
    "_postman_id": "filemanager-service-collection",
    "name": "FileManager Service API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5005", "type": "string" },
    { "key": "tenantId", "value": "", "type": "string" },
    { "key": "authToken", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "serviceSecret", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Authenticated",
      "item": [
        {
          "name": "Upload File",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "x-tenant-id", "value": "{{tenantId}}", "description": "Optional" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/filemanager/files",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "filemanager", "files"]
            },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": "" }
              ]
            }
          }
        },
        {
          "name": "Get File By ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "x-tenant-id", "value": "{{tenantId}}", "description": "Optional" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/filemanager/files/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "filemanager", "files", ":id"],
              "variable": [{ "key": "id", "value": "1" }]
            }
          }
        },
        {
          "name": "Get Files List",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "x-tenant-id", "value": "{{tenantId}}", "description": "Optional" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/filemanager/files?PageNumber=1&PageSize=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "filemanager", "files"],
              "query": [{ "key": "PageNumber", "value": "1" }, { "key": "PageSize", "value": "20" }]
            }
          }
        },
        {
          "name": "Update File Metadata",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-tenant-id", "value": "{{tenantId}}", "description": "Optional" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/filemanager/files/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "filemanager", "files", ":id"],
              "variable": [{ "key": "id", "value": "1" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"updated-filename\",\n  \"description\": \"Updated description\"\n}"
            }
          }
        },
        {
          "name": "Delete File",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "x-tenant-id", "value": "{{tenantId}}", "description": "Optional" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/filemanager/files/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "filemanager", "files", ":id"],
              "variable": [{ "key": "id", "value": "1" }]
            }
          }
        },
        {
          "name": "Download File",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-tenant-id", "value": "{{tenantId}}", "description": "Optional" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/filemanager/files/:id/download",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "filemanager", "files", ":id", "download"],
              "variable": [{ "key": "id", "value": "1" }]
            }
          }
        },
        {
          "name": "Upload File To Blob",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "x-tenant-id", "value": "{{tenantId}}", "description": "Optional" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/filemanager/files/:id/upload-to-blob",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "filemanager", "files", ":id", "upload-to-blob"],
              "variable": [{ "key": "id", "value": "1" }]
            }
          }
        },
        {
          "name": "Remove File From Blob",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "x-tenant-id", "value": "{{tenantId}}", "description": "Optional" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/filemanager/files/:id/remove-from-blob",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "filemanager", "files", ":id", "remove-from-blob"],
              "variable": [{ "key": "id", "value": "1" }]
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Delete File (Admin)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/filemanager/admin/files/:id?tenantId={{tenantId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "filemanager", "admin", "files", ":id"],
              "variable": [{ "key": "id", "value": "1" }],
              "query": [{ "key": "tenantId", "value": "{{tenantId}}", "description": "Optional" }]
            }
          }
        },
        {
          "name": "Delete All Temp Files",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/filemanager/admin/files/temp/all",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "filemanager", "admin", "files", "temp", "all"]
            }
          }
        },
        {
          "name": "Delete Old Temp Files",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/filemanager/admin/files/temp/old?olderThanDays=7",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "filemanager", "admin", "files", "temp", "old"],
              "query": [{ "key": "olderThanDays", "value": "7" }]
            }
          }
        },
        {
          "name": "Upload File To Blob (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/filemanager/admin/files/:id/upload-to-blob?tenantId={{tenantId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "filemanager", "admin", "files", ":id", "upload-to-blob"],
              "variable": [{ "key": "id", "value": "1" }],
              "query": [{ "key": "tenantId", "value": "{{tenantId}}", "description": "Optional" }]
            }
          }
        },
        {
          "name": "Remove File From Blob (Admin)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/filemanager/admin/files/:id/remove-from-blob?tenantId={{tenantId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "filemanager", "admin", "files", ":id", "remove-from-blob"],
              "variable": [{ "key": "id", "value": "1" }],
              "query": [{ "key": "tenantId", "value": "{{tenantId}}", "description": "Optional" }]
            }
          }
        },
        {
          "name": "Get Audit Logs",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/audit-logs?page=1&pageSize=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "audit-logs"],
              "query": [{ "key": "page", "value": "1" }, { "key": "pageSize", "value": "20" }]
            }
          }
        }
      ]
    },
    {
      "name": "Internal",
      "item": [
        {
          "name": "Get File By ID (Internal)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Service-Secret", "value": "{{serviceSecret}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/filemanager/internal/files/:id?tenantId={{tenantId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "filemanager", "internal", "files", ":id"],
              "variable": [{ "key": "id", "value": "1" }],
              "query": [{ "key": "tenantId", "value": "{{tenantId}}", "description": "Optional" }]
            }
          }
        },
        {
          "name": "Get Files By IDs Batch (Internal)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Service-Secret", "value": "{{serviceSecret}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/filemanager/internal/files/batch?fileIds=1&fileIds=2&tenantId={{tenantId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "filemanager", "internal", "files", "batch"],
              "query": [
                { "key": "fileIds", "value": "1" },
                { "key": "fileIds", "value": "2" },
                { "key": "tenantId", "value": "{{tenantId}}", "description": "Optional" }
              ]
            }
          }
        },
        {
          "name": "Change File Temp Status (Internal)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "X-Service-Secret", "value": "{{serviceSecret}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/filemanager/internal/files/:id/temp-status?usageArea=Songs&rowId=123&isNew=true&tenantId={{tenantId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "filemanager", "internal", "files", ":id", "temp-status"],
              "variable": [{ "key": "id", "value": "1" }],
              "query": [
                { "key": "usageArea", "value": "Songs" },
                { "key": "rowId", "value": "123" },
                { "key": "isNew", "value": "true" },
                { "key": "tenantId", "value": "{{tenantId}}", "description": "Optional" }
              ]
            }
          }
        }
      ]
    }
  ]
}
