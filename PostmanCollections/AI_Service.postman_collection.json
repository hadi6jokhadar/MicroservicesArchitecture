      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
          }
        }
      ]
    },
    {
      "name": "Authenticated",
      "item": [
        {
          "name": "Chat Stream (SSE)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-tenant-id", "value": "{{tenantId}}", "description": "Optional" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"settingsKey\": \"default\",\n  \"messages\": [\n    { \"role\": \"user\", \"content\": \"Hello, how can you help me?\" }\n  ],\n  \"sessionId\": null,\n  \"generateSessionTitle\": true\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/chat/stream", "host": ["{{baseUrl}}"], "path": ["api", "v1", "chat", "stream"] },
            "description": "Server-Sent Events streaming response. Returns text/event-stream."
          }
        },
        {
          "name": "Chat Single Response",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-tenant-id", "value": "{{tenantId}}", "description": "Optional" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"settingsKey\": \"default\",\n  \"messages\": [\n    { \"role\": \"user\", \"content\": \"Hello, how can you help me?\" }\n  ],\n  \"sessionId\": null,\n  \"generateSessionTitle\": false\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/chat/single", "host": ["{{baseUrl}}"], "path": ["api", "v1", "chat", "single"] }
          }
        },
        {
          "name": "Create Embedding",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-tenant-id", "value": "{{tenantId}}", "description": "Optional" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"settingsKey\": \"embedding-default\",\n  \"text\": \"Text to embed\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/embedding", "host": ["{{baseUrl}}"], "path": ["api", "v1", "embedding"] }
          }
        }
