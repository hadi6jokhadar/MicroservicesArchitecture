            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated File Name\",\n  \"group\": \"Image\",\n  \"status\": true,\n  \"isArchived\": false,\n  \"temp\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/filemanager/admin/files/1?tenantId={{tenantId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "filemanager", "admin", "files", "1"],
              "query": [
                {
                  "key": "tenantId",
                  "value": "{{tenantId}}"
                }
              ]
            }
          }
        },
        {
          "name": "Delete File (Global)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/filemanager/admin/files/1?tenantId={{tenantId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "filemanager", "admin", "files", "1"],
              "query": [
                {
                  "key": "tenantId",
                  "value": "{{tenantId}}"
                }
              ]
            }
          }
        },
        {
          "name": "Delete All Temp Files",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/filemanager/admin/files/temp/all",
              "host": ["{{baseUrl}}"],
