{
  "info": {
    "_postman_id": "notification-service-collection",
    "name": "Notification Service API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5004", "type": "string" },
    { "key": "tenantId", "value": "", "type": "string" },
    { "key": "authToken", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "serviceSecret", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Authenticated",
      "item": [
        {
          "name": "Get My Notifications",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "x-tenant-id", "value": "{{tenantId}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/notifications/user",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "notifications", "user"]
            }
          }
        },
        {
          "name": "Mark Notification As Read",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "x-tenant-id", "value": "{{tenantId}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/notifications/:id/read",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "notifications", ":id", "read"],
              "variable": [{ "key": "id", "value": "1" }]
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Send Notification",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/notifications/send",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "notifications", "send"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": 1,\n  \"tenantId\": \"{{tenantId}}\",\n  \"title\": \"Hello!\",\n  \"body\": \"You have a new message.\",\n  \"deliveryType\": 1\n}"
            }
          }
        },
        {
          "name": "Get Queue Item Status",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/notifications/status/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "notifications", "status", ":id"],
              "variable": [{ "key": "id", "value": "1" }]
            }
          }
        },
        {
          "name": "Get Queue Items",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/notifications/queue?page=1&pageSize=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "notifications", "queue"],
              "query": [{ "key": "page", "value": "1" }, { "key": "pageSize", "value": "20" }]
            }
          }
        },
        {
          "name": "Toggle Queue Item Archived Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/notifications/queue/:id/toggle-archive",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "notifications", "queue", ":id", "toggle-archive"],
              "variable": [{ "key": "id", "value": "1" }]
            }
          }
        },
        {
          "name": "Get Audit Logs",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/audit-logs?page=1&pageSize=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "audit-logs"],
              "query": [{ "key": "page", "value": "1" }, { "key": "pageSize", "value": "20" }]
            }
          }
        }
      ]
    }
  ]
}
