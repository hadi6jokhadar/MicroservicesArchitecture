{
  "info": {
    "_postman_id": "translation-service-collection",
    "name": "Translation Service API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5006", "type": "string" },
    { "key": "tenantId", "value": "", "type": "string" },
    { "key": "authToken", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "serviceSecret", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Public",
      "item": [
        {
          "name": "Get Translations By Language",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-tenant-id", "value": "{{tenantId}}", "description": "Optional - includes tenant overrides when provided" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/translations/:language",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "translations", ":language"],
              "variable": [{ "key": "language", "value": "en" }]
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Get Translation Keys",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/translations/keys?page=1&pageSize=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "translations", "keys"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "20" },
                { "key": "category", "value": "", "disabled": true },
                { "key": "search", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Create Translation Key",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/translations/keys",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "translations", "keys"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"key\": \"common.save\",\n  \"category\": \"common\",\n  \"description\": \"Save button label\"\n}"
            }
          }
        },
        {
          "name": "Update Translation Key",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/translations/keys/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "translations", "keys", ":id"],
              "variable": [{ "key": "id", "value": "1" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Updated description\"\n}"
            }
          }
        },
        {
          "name": "Delete Translation Key",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/translations/keys/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "translations", "keys", ":id"],
              "variable": [{ "key": "id", "value": "1" }]
            }
          }
        },
        {
          "name": "Toggle Translation Key Archived Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/translations/keys/:id/toggle-archive",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "translations", "keys", ":id", "toggle-archive"],
              "variable": [{ "key": "id", "value": "1" }]
            }
          }
        },
        {
          "name": "Set Translation Value",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/translations/values",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "translations", "values"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"keyId\": 1,\n  \"language\": \"en\",\n  \"value\": \"Save\",\n  \"tenantId\": null\n}"
            }
          }
        },
        {
          "name": "Delete Translation Value",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/translations/values/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "translations", "values", ":id"],
              "variable": [{ "key": "id", "value": "1" }]
            }
          }
        },
        {
          "name": "Import Translations",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/translations/import",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "translations", "import"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"language\": \"en\",\n  \"translations\": {\n    \"common.save\": \"Save\",\n    \"common.cancel\": \"Cancel\"\n  }\n}"
            }
          }
        },
        {
          "name": "Get Audit Logs",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/audit-logs?page=1&pageSize=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "audit-logs"],
              "query": [{ "key": "page", "value": "1" }, { "key": "pageSize", "value": "20" }]
            }
          }
        }
      ]
    }
  ]
}
