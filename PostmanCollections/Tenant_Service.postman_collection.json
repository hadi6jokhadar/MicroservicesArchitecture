{
  "info": {
    "_postman_id": "tenant-service-collection",
    "name": "Tenant Service API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5002", "type": "string" },
    { "key": "tenantId", "value": "your-tenant-id", "type": "string" },
    { "key": "authToken", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "serviceSecret", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Public",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
          }
        },
        {
          "name": "Health Readiness",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/health/ready", "host": ["{{baseUrl}}"], "path": ["health", "ready"] }
          }
        },
        {
          "name": "Get Tenant by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/tenant/:tenantId", "host": ["{{baseUrl}}"], "path": ["api", "tenant", ":tenantId"], "variable": [{ "key": "tenantId", "value": "{{tenantId}}" }] }
          }
        }
      ]
    },
    {
      "name": "Authenticated",
      "item": [
        {
          "name": "Get Tenant Config",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/tenant/config/:tenantId", "host": ["{{baseUrl}}"], "path": ["api", "tenant", "config", ":tenantId"], "variable": [{ "key": "tenantId", "value": "{{tenantId}}" }] }
          }
        },
        {
          "name": "Get All Active Tenants with Config",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/tenant/config?page=1&pageSize=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tenant", "config"],
              "query": [{ "key": "page", "value": "1" }, { "key": "pageSize", "value": "20" }]
            }
          }
        }
      ]
    },
    {
      "name": "Audit Logs",
      "item": [
        {
          "name": "Get Audit Logs",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "x-tenant-id", "value": "{{tenantId}}", "description": "Optional — OptionalTenantAttribute" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/audit-logs",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "audit-logs"],
              "query": [
                { "key": "tenantId",   "value": "", "disabled": true, "description": "Filter by tenant ID" },
                { "key": "entityType", "value": "", "disabled": true, "description": "Filter by entity type (e.g. User, CategoryEntity)" },
                { "key": "action",     "value": "", "disabled": true, "description": "Filter by action substring (e.g. Deleted, Updated)" },
                { "key": "userId",     "value": "", "disabled": true, "description": "Filter by user who made the change" },
                { "key": "userEmail",  "value": "", "disabled": true, "description": "Filter by user email substring" },
                { "key": "fromDate",   "value": "", "disabled": true, "description": "ISO 8601 UTC start timestamp, e.g. 2026-01-01T00:00:00Z" },
                { "key": "toDate",     "value": "", "disabled": true, "description": "ISO 8601 UTC end timestamp" },
                { "key": "sortBy",     "value": "OccurredAt", "disabled": true, "description": "OccurredAt | Action | EntityType | EntityId | UserId" },
                { "key": "sortDesc",   "value": "true", "disabled": true, "description": "Sort direction (default: true)" },
                { "key": "page",       "value": "1", "disabled": true, "description": "Page number, 1-based (default: 1)" },
                { "key": "pageSize",   "value": "20", "disabled": true, "description": "Items per page, max 100 (default: 20)" }
              ]
            },
            "description": "Returns PaginatedList<AuditLogDto>. Requires Admin or SuperAdmin role."
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Get All Active Tenants",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/tenant/?page=1&pageSize=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "tenant", ""],
              "query": [{ "key": "page", "value": "1" }, { "key": "pageSize", "value": "20" }]
            }
          }
        },
        {
          "name": "Get Tenant by User ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/admin/tenant/user/:userId", "host": ["{{baseUrl}}"], "path": ["api", "admin", "tenant", "user", ":userId"], "variable": [{ "key": "userId", "value": "1" }] }
          }
        },
        {
          "name": "Create Tenant",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Acme Corp\",\n  \"identifier\": \"acme\",\n  \"databaseProvider\": \"PostgreSql\",\n  \"connectionString\": \"Host=localhost;Database=acme_db;Username=user;Password=pass\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/admin/tenant/", "host": ["{{baseUrl}}"], "path": ["api", "admin", "tenant", ""] }
          }
        },
        {
          "name": "Update Tenant",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Acme Corporation\",\n  \"allowedOrigins\": [\"https://acme.example.com\"]\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/admin/tenant/:tenantId", "host": ["{{baseUrl}}"], "path": ["api", "admin", "tenant", ":tenantId"], "variable": [{ "key": "tenantId", "value": "{{tenantId}}" }] }
          }
        },
        {
          "name": "Delete Tenant",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/admin/tenant/:tenantId", "host": ["{{baseUrl}}"], "path": ["api", "admin", "tenant", ":tenantId"], "variable": [{ "key": "tenantId", "value": "{{tenantId}}" }] }
          }
        },
        {
          "name": "Toggle Tenant Archived Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/admin/tenant/:tenantId/toggle-archive", "host": ["{{baseUrl}}"], "path": ["api", "admin", "tenant", ":tenantId", "toggle-archive"], "variable": [{ "key": "tenantId", "value": "{{tenantId}}" }] }
          }
        }
      ]
    }
  ]
}
