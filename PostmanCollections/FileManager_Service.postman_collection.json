{
  "info": {
    "name": "FileManager Service API",
    "description": "Postman collection for FileManager microservice endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5005",
      "type": "string"
    },
    {
      "key": "tenantId",
      "value": "your-tenant-id",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "your-jwt-token",
      "type": "string"
    },
    {
      "key": "serviceSecret",
      "value": "CHANGE_ME_SHARED_SECRET",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "item": [
        {
          "name": "Get Service Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/",
              "host": ["{{baseUrl}}"],
              "path": [""]
            }
          }
        }
      ]
    },
    {
      "name": "Tenant User Endpoints",
      "item": [
        {
          "name": "Upload File",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}",
                "type": "text"
              },
              {
                "key": "x-tenant-id",
                "value": "{{tenantId}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": []
                },
                {
                  "key": "group",
                  "value": "1",
                  "type": "text"
                },
                {
                  "key": "userId",
                  "value": "1",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/filemanager/files",
              "host": ["{{baseUrl}}"],
              "path": ["api", "filemanager", "files"]
            }
          }
        },
        {
          "name": "Get File by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}",
                "type": "text"
              },
              {
                "key": "x-tenant-id",
                "value": "{{tenantId}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/filemanager/files/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "filemanager", "files", "1"]
            }
          }
        },
        {
          "name": "Get Files List",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}",
                "type": "text"
              },
              {
                "key": "x-tenant-id",
                "value": "{{tenantId}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/filemanager/files?pageNumber=1&pageSize=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "filemanager", "files"],
              "query": [
                {
                  "key": "pageNumber",
                  "value": "1"
                },
                {
                  "key": "pageSize",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "Update File Metadata",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}",
                "type": "text"
              },
              {
                "key": "x-tenant-id",
                "value": "{{tenantId}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated File Name\",\n  \"group\": \"Image\",\n  \"status\": true,\n  \"isArchived\": false,\n  \"temp\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/filemanager/files/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "filemanager", "files", "1"]
            }
          }
        },
        {
          "name": "Delete File",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}",
                "type": "text"
              },
              {
                "key": "x-tenant-id",
                "value": "{{tenantId}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/filemanager/files/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "filemanager", "files", "1"]
            }
          }
        },
        {
          "name": "Download File",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/filemanager/files/1/download",
              "host": ["{{baseUrl}}"],
              "path": ["api", "filemanager", "files", "1", "download"]
            }
          }
        }
      ]
    },
