{
  "info": {
    "_postman_id": "nasheed-service-collection",
    "name": "Nasheed Service API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5009", "type": "string" },
    { "key": "tenantId", "value": "your-tenant-id", "type": "string" },
    { "key": "authToken", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "serviceSecret", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Public",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
          }
        },
        {
          "name": "Health Readiness",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/health/ready", "host": ["{{baseUrl}}"], "path": ["health", "ready"] }
          }
        }
      ]
    },
    {
      "name": "Authenticated",
      "item": [
        {
          "name": "Artists",
          "item": [
            {
              "name": "Get Artist List",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{authToken}}" },
                  { "key": "x-tenant-id", "value": "{{tenantId}}" }
                ],
                "url": {
                  "raw": "{{baseUrl}}/api/artists/?page=1&pageSize=20",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "artists", ""],
                  "query": [{ "key": "page", "value": "1" }, { "key": "pageSize", "value": "20" }]
                }
              }
            },
            {
              "name": "Get Artist by ID",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{authToken}}" },
                  { "key": "x-tenant-id", "value": "{{tenantId}}" }
                ],
                "url": { "raw": "{{baseUrl}}/api/artists/:id", "host": ["{{baseUrl}}"], "path": ["api", "artists", ":id"], "variable": [{ "key": "id", "value": "1" }] }
              }
            },
            {
              "name": "Create Artist",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{authToken}}" },
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "x-tenant-id", "value": "{{tenantId}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Artist Name\",\n  \"bio\": \"Artist biography\",\n  \"profileImageId\": null\n}"
                },
                "url": { "raw": "{{baseUrl}}/api/artists/", "host": ["{{baseUrl}}"], "path": ["api", "artists", ""] }
              }
            },
            {
              "name": "Update Artist",
              "request": {
                "method": "PUT",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{authToken}}" },
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "x-tenant-id", "value": "{{tenantId}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Updated Artist Name\",\n  \"bio\": \"Updated biography\"\n}"
                },
                "url": { "raw": "{{baseUrl}}/api/artists/:id", "host": ["{{baseUrl}}"], "path": ["api", "artists", ":id"], "variable": [{ "key": "id", "value": "1" }] }
              }
            },
            {
              "name": "Delete Artist",
              "request": {
                "method": "DELETE",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{authToken}}" },
                  { "key": "x-tenant-id", "value": "{{tenantId}}" }
                ],
                "url": { "raw": "{{baseUrl}}/api/artists/:id", "host": ["{{baseUrl}}"], "path": ["api", "artists", ":id"], "variable": [{ "key": "id", "value": "1" }] }
              }
            }
          ]
        },
        {
          "name": "Songs",
          "item": [
            {
              "name": "Get Song List",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{authToken}}" },
                  { "key": "x-tenant-id", "value": "{{tenantId}}" }
                ],
                "url": {
                  "raw": "{{baseUrl}}/api/songs/?page=1&pageSize=20",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "songs", ""],
                  "query": [{ "key": "page", "value": "1" }, { "key": "pageSize", "value": "20" }]
                }
              }
            },
            {
              "name": "Get Song by ID",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{authToken}}" },
                  { "key": "x-tenant-id", "value": "{{tenantId}}" }
                ],
                "url": { "raw": "{{baseUrl}}/api/songs/:id", "host": ["{{baseUrl}}"], "path": ["api", "songs", ":id"], "variable": [{ "key": "id", "value": "1" }] }
              }
            },
            {
              "name": "Get Song Analysis Status",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{authToken}}" },
                  { "key": "x-tenant-id", "value": "{{tenantId}}" }
                ],
                "url": { "raw": "{{baseUrl}}/api/songs/:id/analysis", "host": ["{{baseUrl}}"], "path": ["api", "songs", ":id", "analysis"], "variable": [{ "key": "id", "value": "1" }] }
              }
            },
            {
              "name": "Get Similar Songs",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{authToken}}" },
                  { "key": "x-tenant-id", "value": "{{tenantId}}" }
                ],
                "url": {
                  "raw": "{{baseUrl}}/api/songs/:id/similar?topN=10",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "songs", ":id", "similar"],
                  "query": [{ "key": "topN", "value": "10" }],
                  "variable": [{ "key": "id", "value": "1" }]
                }
              }
            },
            {
              "name": "Create Song",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{authToken}}" },
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "x-tenant-id", "value": "{{tenantId}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"title\": \"Song Title\",\n  \"artistId\": 1,\n  \"audioFileId\": 1,\n  \"lyrics\": \"Song lyrics here\"\n}"
                },
                "url": { "raw": "{{baseUrl}}/api/songs/", "host": ["{{baseUrl}}"], "path": ["api", "songs", ""] }
              }
            },
            {
              "name": "Update Song",
              "request": {
                "method": "PUT",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{authToken}}" },
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "x-tenant-id", "value": "{{tenantId}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"title\": \"Updated Song Title\",\n  \"lyrics\": \"Updated lyrics\"\n}"
                },
                "url": { "raw": "{{baseUrl}}/api/songs/:id", "host": ["{{baseUrl}}"], "path": ["api", "songs", ":id"], "variable": [{ "key": "id", "value": "1" }] }
              }
            },
            {
              "name": "Delete Song",
              "request": {
                "method": "DELETE",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{authToken}}" },
                  { "key": "x-tenant-id", "value": "{{tenantId}}" }
                ],
                "url": { "raw": "{{baseUrl}}/api/songs/:id", "host": ["{{baseUrl}}"], "path": ["api", "songs", ":id"], "variable": [{ "key": "id", "value": "1" }] }
              }
            }
          ]
        },
        {
          "name": "Interactions",
          "item": [
            {
              "name": "Add Favorite",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{authToken}}" },
                  { "key": "x-tenant-id", "value": "{{tenantId}}" }
                ],
                "url": { "raw": "{{baseUrl}}/api/songs/:songId/favorites", "host": ["{{baseUrl}}"], "path": ["api", "songs", ":songId", "favorites"], "variable": [{ "key": "songId", "value": "1" }] }
              }
            },
            {
              "name": "Remove Favorite",
              "request": {
                "method": "DELETE",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{authToken}}" },
                  { "key": "x-tenant-id", "value": "{{tenantId}}" }
                ],
                "url": { "raw": "{{baseUrl}}/api/songs/:songId/favorites", "host": ["{{baseUrl}}"], "path": ["api", "songs", ":songId", "favorites"], "variable": [{ "key": "songId", "value": "1" }] }
              }
            },
            {
              "name": "Add Rating",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{authToken}}" },
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "x-tenant-id", "value": "{{tenantId}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"score\": 5\n}"
                },
                "url": { "raw": "{{baseUrl}}/api/songs/:songId/ratings", "host": ["{{baseUrl}}"], "path": ["api", "songs", ":songId", "ratings"], "variable": [{ "key": "songId", "value": "1" }] }
              }
            },
            {
              "name": "Log Play",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{authToken}}" },
                  { "key": "x-tenant-id", "value": "{{tenantId}}" }
                ],
                "url": { "raw": "{{baseUrl}}/api/songs/:songId/play", "host": ["{{baseUrl}}"], "path": ["api", "songs", ":songId", "play"], "variable": [{ "key": "songId", "value": "1" }] }
              }
            }
          ]
        },
        {
          "name": "Search",
          "item": [
            {
              "name": "Search Songs",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{authToken}}" },
                  { "key": "x-tenant-id", "value": "{{tenantId}}" }
                ],
                "url": {
                  "raw": "{{baseUrl}}/api/search/?q=nasheed&topN=10",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "search", ""],
                  "query": [{ "key": "q", "value": "nasheed" }, { "key": "topN", "value": "10" }]
                }
              }
            }
          ]
        },
        {
          "name": "Ingestion",
          "item": [
            {
              "name": "Get Ingestion Job List",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{authToken}}" },
                  { "key": "x-tenant-id", "value": "{{tenantId}}" }
                ],
                "url": {
                  "raw": "{{baseUrl}}/api/ingestion/?page=1&pageSize=20",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "ingestion", ""],
                  "query": [{ "key": "page", "value": "1" }, { "key": "pageSize", "value": "20" }]
                }
              }
            },
            {
              "name": "Get Ingestion Job by ID",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{authToken}}" },
                  { "key": "x-tenant-id", "value": "{{tenantId}}" }
                ],
                "url": { "raw": "{{baseUrl}}/api/ingestion/:id", "host": ["{{baseUrl}}"], "path": ["api", "ingestion", ":id"], "variable": [{ "key": "id", "value": "1" }] }
              }
            },
            {
              "name": "Retry Ingestion Job",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{authToken}}" },
                  { "key": "x-tenant-id", "value": "{{tenantId}}" }
                ],
                "url": { "raw": "{{baseUrl}}/api/ingestion/:id/retry", "host": ["{{baseUrl}}"], "path": ["api", "ingestion", ":id", "retry"], "variable": [{ "key": "id", "value": "1" }] }
              }
            },
            {
              "name": "Reindex Song",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{authToken}}" },
                  { "key": "x-tenant-id", "value": "{{tenantId}}" }
                ],
                "url": { "raw": "{{baseUrl}}/api/ingestion/songs/:songId/reindex", "host": ["{{baseUrl}}"], "path": ["api", "ingestion", "songs", ":songId", "reindex"], "variable": [{ "key": "songId", "value": "1" }] }
              }
            },
            {
              "name": "Remove Ingestion Job",
              "request": {
                "method": "DELETE",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{authToken}}" },
                  { "key": "x-tenant-id", "value": "{{tenantId}}" }
                ],
                "url": { "raw": "{{baseUrl}}/api/ingestion/:id", "host": ["{{baseUrl}}"], "path": ["api", "ingestion", ":id"], "variable": [{ "key": "id", "value": "1" }] }
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Generate Lyrics",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-tenant-id", "value": "{{tenantId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"theme\": \"gratitude\",\n  \"language\": \"ar\",\n  \"style\": \"traditional\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/generation/lyrics", "host": ["{{baseUrl}}"], "path": ["api", "generation", "lyrics"] }
          }
        }
      ]
    }
  ]
}
