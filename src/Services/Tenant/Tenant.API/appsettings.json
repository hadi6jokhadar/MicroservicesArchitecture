{
  "Urls": "http://localhost:5002",

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.Diagnostics.ExceptionHandlerMiddleware": "None",
      "Microsoft.EntityFrameworkCore": "Information",
      "IhsanDev.Shared.Application.Common.Behaviors.LoggingBehavior": "Information",
      "IhsanDev.Shared.Infrastructure.Middleware.GlobalExceptionHandler": "Information"
    },
    "FilePath": "C:\\Users\\YOUR_USERNAME\\Desktop\\Projects\\MicroservicesArchitecture\\Logs"
  },
  "AllowedHosts": "*",

  "DatabaseSettings": {
    "Provider": "PostgreSql",
    "ConnectionString": "Host=localhost;Port=5432;Database=tenant;Username=postgres;Password=CHANGE_ME_DB_PASSWORD;Minimum Pool Size=5;Maximum Pool Size=50;Connection Idle Lifetime=300;Connection Pruning Interval=10;Pooling=true;",
    "EnableSensitiveDataLogging": false,
    "EnableDetailedErrors": false,
    "CommandTimeout": 30,
    "MaxRetryCount": 3,
    "MaxRetryDelay": 30
  },

  "Jwt": {
    "Secret": "CHANGE_ME_JWT_SECRET",
    "Issuer": "IhsanDev",
    "Audience": "MicroservicesApp",
    "AccessTokenExpirationMinutes": 21600,
    "RefreshTokenExpirationDays": 7
  },

  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5001",
      "http://localhost:5005",
      "http://localhost:5008",
      "http://localhost:4200",
      "http://localhost:4300",
      "http://localhost:4301"
    ]
  },

  "Redis": {
    "Enabled": true,
    "ConnectionString": "localhost:6379,abortConnect=false",
    "InstanceName": "MicroservicesApp:"
  },

  "MultiTenancy": {
    "CacheExpirationMinutes": 60
  },

  "ServiceCommunication": {
    "Enabled": true,
    "ServiceName": "TenantService",
    "SharedSecret": "CHANGE_ME_SHARED_SECRET",
    "AllowedServices": [
      "IdentityService",
      "NotificationService",
      "FileManagerService"
    ]
  },

  "Observability": {
    "OtlpEndpoint": "http://localhost:4317"
  },

  "RateLimiting": {
    "Global": {
      "PermitLimit": 20000,
      "WindowMinutes": 1
    },
    "PerIP": {
      "PermitLimit": 200,
      "WindowMinutes": 1
    },
    "PerTenant": {
      "PermitLimit": 5000,
      "WindowMinutes": 1
    }
  },
  "Hangfire": {
    "Dashboard": {
      "Username": "admin",
      "Password": "CHANGE_ME_HANGFIRE_PASSWORD"
    }
  }
}
