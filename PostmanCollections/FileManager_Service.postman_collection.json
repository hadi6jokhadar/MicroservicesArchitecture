      ]
    },
    {
      "name": "Internal Service Endpoints",
      "item": [
        {
          "name": "Get File by ID (Internal)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Service-Secret",
                "value": "{{serviceSecret}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/filemanager/internal/files/1?tenantId={{tenantId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "filemanager", "internal", "files", "1"],
              "query": [
                {
                  "key": "tenantId",
                  "value": "{{tenantId}}"
                }
              ]
            }
          }
        },
        {
          "name": "Get Files by IDs (Batch)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Service-Secret",
                "value": "{{serviceSecret}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/filemanager/internal/files/batch?fileIds=1&fileIds=2&tenantId={{tenantId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "filemanager", "internal", "files", "batch"],
              "query": [
                {
                  "key": "fileIds",
                  "value": "1"
                },
                {
                  "key": "fileIds",
                  "value": "2"
                },
                {
                  "key": "tenantId",
                  "value": "{{tenantId}}"
                }
              ]
            }
          }
        },
        {
          "name": "Change Temp Status",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "X-Service-Secret",
                "value": "{{serviceSecret}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/filemanager/internal/files/1/temp-status?temp=false&tenantId={{tenantId}}",
              "host": ["{{baseUrl}}"],
              "path": [
                "api",
                "filemanager",
                "internal",
                "files",
                "1",
                "temp-status"
              ],
              "query": [
                {
                  "key": "temp",
                  "value": "false"
                },
                {
                  "key": "tenantId",
