{
  "Urls": "http://localhost:5000",

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp.ReverseProxy": "Warning"
    }
  },
  "AllowedHosts": "*",

  // Token bucket: TokenLimit = immediate burst capacity, TokensPerPeriod = steady sustained
  // rate (refills every ReplenishmentSeconds). E.g. Global below allows a 20,000-request burst
  // then throttles to 5,000 req/s indefinitely — comfortably covers 100k+ requests within
  // seconds while still bounding a runaway/DDoS scenario. PerIpAuth is a SEPARATE per-IP bucket
  // from PerIp so general API traffic can never starve login/register/refresh of their budget.
  "RateLimiting": {
    "Global": {
      "TokenLimit": 20000,
      "TokensPerPeriod": 5000,
      "ReplenishmentSeconds": 1
    },
    "PerIp": {
      "TokenLimit": 5000,
      "TokensPerPeriod": 2000,
      "ReplenishmentSeconds": 1
    },
    "PerIpAuth": {
      "TokenLimit": 20,
      "TokensPerPeriod": 5,
      "ReplenishmentSeconds": 1
    }
  },

  "ReverseProxy": {
    "Routes": {
      // ── Audit Log Routes (all services, Order 4 — beats all admin catch-alls) ──
      // Each service exposes GET /api/admin/audit-logs internally (unversioned infrastructure endpoint).
      // The gateway maps versioned public paths and rewrites before forwarding.
      "identity-audit-logs-route": {
        "ClusterId": "identity",
        "Order": 4,
        "Match": { "Path": "/api/v1/admin/audit-logs" },
        "Transforms": [{ "PathPattern": "/api/admin/audit-logs" }]
      },
      "tenant-audit-logs-route": {
        "ClusterId": "tenant",
        "Order": 4,
        "Match": { "Path": "/api/v1/admin/tenant/audit-logs" },
        "Transforms": [{ "PathPattern": "/api/admin/audit-logs" }]
      },
      "filemanager-audit-logs-route": {
        "ClusterId": "filemanager",
        "Order": 4,
        "Match": { "Path": "/api/v1/admin/filemanager/audit-logs" },
        "Transforms": [{ "PathPattern": "/api/admin/audit-logs" }]
      },
      "notification-audit-logs-route": {
        "ClusterId": "notification",
        "Order": 4,
        "Match": { "Path": "/api/v1/admin/notifications/audit-logs" },
        "Transforms": [{ "PathPattern": "/api/admin/audit-logs" }]
      },
      "translation-audit-logs-route": {
        "ClusterId": "translation",
        "Order": 4,
        "Match": { "Path": "/api/v1/admin/translations/audit-logs" },
        "Transforms": [{ "PathPattern": "/api/admin/audit-logs" }]
      },
      "category-audit-logs-route": {
        "ClusterId": "category",
        "Order": 4,
        "Match": { "Path": "/api/v1/admin/categories/audit-logs" },
        "Transforms": [{ "PathPattern": "/api/admin/audit-logs" }]
      },
      "nasheed-audit-logs-route": {
        "ClusterId": "nasheed",
        "Order": 4,
        "Match": { "Path": "/api/v1/admin/nasheed/audit-logs" },
        "Transforms": [{ "PathPattern": "/api/admin/audit-logs" }]
      },

      // ── Identity Service ────────────────────────────────────────────────
      // More-specific admin sub-routes for other services are declared before
      // the catch-all identity-admin-route so that ASP.NET Core routing
      // resolves them first.

      "identity-auth-route": {
        "ClusterId": "identity",
        "Order": 10,
        "Match": { "Path": "/api/v1/auth/{**catch-all}" }
      },
      "identity-user-route": {
        "ClusterId": "identity",
        "Order": 10,
        "Match": { "Path": "/api/v1/user/{**catch-all}" }
      },
      "identity-roles-route": {
        "ClusterId": "identity",
        "Order": 10,
        "Match": { "Path": "/api/v1/roles/{**catch-all}" }
      },
      "identity-claims-route": {
        "ClusterId": "identity",
        "Order": 10,
        "Match": { "Path": "/api/v1/claims/{**catch-all}" }
      },
      "identity-device-tokens-route": {
        "ClusterId": "identity",
        "Order": 10,
        "Match": { "Path": "/api/v1/device-tokens/{**catch-all}" }
      },
      // /api/v1/admin/* that is NOT /api/v1/admin/tenant or /api/v1/admin/categories
      // goes to Identity. Declare at higher order (lower priority number) so
      // tenant and category admin routes win when paths overlap.
      "identity-admin-route": {
        "ClusterId": "identity",
        "Order": 20,
        "Match": { "Path": "/api/v1/admin/{**catch-all}" }
      },

      // ── Tenant Service ──────────────────────────────────────────────────
      "tenant-route": {
        "ClusterId": "tenant",
        "Order": 10,
        "Match": { "Path": "/api/v1/tenant/{**catch-all}" }
      },
      "tenant-admin-route": {
        "ClusterId": "tenant",
        "Order": 5,
        "Match": { "Path": "/api/v1/admin/tenant/{**catch-all}" }
      },

      // ── Notification Service ────────────────────────────────────────────
      "notification-route": {
        "ClusterId": "notification",
        "Order": 10,
        "Match": { "Path": "/api/v1/notifications/{**catch-all}" }
      },

      // ── FileManager Service ─────────────────────────────────────────────
      "filemanager-route": {
        "ClusterId": "filemanager",
        "Order": 10,
        "Match": { "Path": "/api/v1/filemanager/{**catch-all}" }
      },

      // ── Translation Service ─────────────────────────────────────────────
      "translation-route": {
        "ClusterId": "translation",
        "Order": 10,
        "Match": { "Path": "/api/v1/translations/{**catch-all}" }
      },

      // ── Category Service ────────────────────────────────────────────────
      "category-route": {
        "ClusterId": "category",
        "Order": 10,
        "Match": { "Path": "/api/v1/categories/{**catch-all}" }
      },
      "category-admin-route": {
        "ClusterId": "category",
        "Order": 5,
        "Match": { "Path": "/api/v1/admin/categories/{**catch-all}" }
      },

      // ── AI Service (Python / FastAPI on port 5008) ──────────────────────
      // AI service already uses /api/v1/ — no change needed.
      // Stream route: SSE — disable buffering, extend timeout, remove Content-Length.
      // Must be declared before ai-route so the more-specific path wins.
      "ai-stream-route": {
        "ClusterId": "ai",
        "Order": 3,
        "Match": { "Path": "/api/v1/ai/chat/stream" },
        "Transforms": [
          { "PathPattern": "/api/v1/chat/stream" },
          { "ResponseHeaderRemove": "Content-Length" }
        ],
        "Timeout": "00:10:00"
      },
      // Non-stream AI route — standard JSON response.
      "ai-route": {
        "ClusterId": "ai",
        "Order": 10,
        "Match": { "Path": "/api/v1/ai/{**catch-all}" },
        "Transforms": [{ "PathPattern": "/api/v1/{**catch-all}" }]
      },

      // ── Nasheed App ─────────────────────────────────────────────────────
      "nasheed-artists-route": {
        "ClusterId": "nasheed",
        "Order": 10,
        "Match": { "Path": "/api/v1/artists/{**catch-all}" }
      },
      "nasheed-songs-route": {
        "ClusterId": "nasheed",
        "Order": 10,
        "Match": { "Path": "/api/v1/songs/{**catch-all}" }
      },
      "nasheed-ingestion-route": {
        "ClusterId": "nasheed",
        "Order": 10,
        "Match": { "Path": "/api/v1/ingestion/{**catch-all}" }
      },
      "nasheed-search-route": {
        "ClusterId": "nasheed",
        "Order": 10,
        "Match": { "Path": "/api/v1/search/{**catch-all}" }
      },
      "nasheed-generation-route": {
        "ClusterId": "nasheed",
        "Order": 10,
        "Match": { "Path": "/api/v1/generation/{**catch-all}" }
      }
    },

    "Clusters": {
      "identity": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5001" }
        }
      },
      "tenant": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5002" }
        }
      },
      "notification": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5004" }
        }
      },
      "filemanager": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5005" }
        }
      },
      "translation": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5006" }
        }
      },
      "category": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5007" }
        }
      },
      "ai": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5008" }
        }
      },
      "nasheed": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5009" }
        }
      }
    }
  }
}
