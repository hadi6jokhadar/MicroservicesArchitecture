{
  "info": {
    "_postman_id": "category-service-collection",
    "name": "Category Service API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5007", "type": "string" },
    { "key": "tenantId", "value": "", "type": "string" },
    { "key": "authToken", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "serviceSecret", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Authenticated",
      "item": [
        {
          "name": "Get Category Tree",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "x-tenant-id", "value": "{{tenantId}}", "description": "Optional" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/categories/tree",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "categories", "tree"]
            }
          }
        },
        {
          "name": "Get Category List",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "x-tenant-id", "value": "{{tenantId}}", "description": "Optional" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/categories/?page=1&pageSize=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "categories", ""],
              "query": [{ "key": "page", "value": "1" }, { "key": "pageSize", "value": "20" }]
            }
          }
        },
        {
          "name": "Get Category By ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "x-tenant-id", "value": "{{tenantId}}", "description": "Optional" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/categories/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "categories", ":id"],
              "variable": [{ "key": "id", "value": "1" }]
            }
          }
        },
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-tenant-id", "value": "{{tenantId}}", "description": "Optional" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/categories/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "categories", ""]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Electronics\",\n  \"parentId\": null,\n  \"order\": 1\n}"
            }
          }
        },
        {
          "name": "Update Category",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-tenant-id", "value": "{{tenantId}}", "description": "Optional" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/categories/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "categories", ":id"],
              "variable": [{ "key": "id", "value": "1" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Electronics Updated\",\n  \"order\": 2\n}"
            }
          }
        },
        {
          "name": "Move Category",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-tenant-id", "value": "{{tenantId}}", "description": "Optional" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/categories/:id/move",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "categories", ":id", "move"],
              "variable": [{ "key": "id", "value": "1" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"newParentId\": 2\n}"
            }
          }
        },
        {
          "name": "Delete Category",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "x-tenant-id", "value": "{{tenantId}}", "description": "Optional" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/categories/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "categories", ":id"],
              "variable": [{ "key": "id", "value": "1" }]
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Admin Get Category Tree",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/categories/tree",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "categories", "tree"]
            }
          }
        },
        {
          "name": "Admin Get Category List",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/categories/?page=1&pageSize=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "categories", ""],
              "query": [{ "key": "page", "value": "1" }, { "key": "pageSize", "value": "20" }]
            }
          }
        },
        {
          "name": "Get Audit Logs",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/audit-logs?page=1&pageSize=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "audit-logs"],
              "query": [{ "key": "page", "value": "1" }, { "key": "pageSize", "value": "20" }]
            }
          }
        }
      ]
    },
    {
      "name": "Internal",
      "item": [
        {
          "name": "Get Category Snapshot",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Service-Secret", "value": "{{serviceSecret}}" },
              { "key": "x-tenant-id", "value": "{{tenantId}}", "description": "Optional - scope by tenant" }
            ],
            "url": {
              "raw": "{{baseUrl}}/internal/categories/snapshot",
              "host": ["{{baseUrl}}"],
              "path": ["internal", "categories", "snapshot"]
            }
          }
        }
      ]
    }
  ]
}
