{
  "info": {
    "name": "Notification Service API",
    "description": "Postman collection for Notification microservice endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5004",
      "type": "string"
    },
    {
      "key": "tenantId",
      "value": "your-tenant-id",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "your-jwt-token",
      "type": "string"
    },
    {
      "key": "serviceSecret",
      "value": "CHANGE_ME_SHARED_SECRET",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "item": [
        {
          "name": "Get Service Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          }
        }
      ]
    },
    {
      "name": "Service/Admin Endpoints",
      "item": [
        {
          "name": "Send Notification",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": 1,\n  \"title\": \"Test Notification\",\n  \"body\": \"This is a test notification\",\n  \"data\": {\n    \"key\": \"value\"\n  },\n  \"tenantId\": \"{{tenantId}}\",\n  \"priority\": \"Normal\",\n  \"type\": \"General\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/notifications/send",
              "host": ["{{baseUrl}}"],
              "path": ["api", "notifications", "send"]
            }
          }
        },
        {
          "name": "Get Queue Item Status",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/notifications/status/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "notifications", "status", "1"]
            }
          }
        },
        {
          "name": "Get Queue Items",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/notifications/queue?pageNumber=1&pageSize=10&status=Pending",
              "host": ["{{baseUrl}}"],
              "path": ["api", "notifications", "queue"],
              "query": [
                {
                  "key": "pageNumber",
                  "value": "1"
                },
                {
                  "key": "pageSize",
                  "value": "10"
                },
                {
                  "key": "status",
                  "value": "Pending"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "User Endpoints",
      "item": [
        {
          "name": "Get User Notifications",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}",
                "type": "text"
              },
              {
                "key": "x-tenant-id",
                "value": "{{tenantId}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/notifications/user?pageNumber=1&pageSize=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "notifications", "user"],
              "query": [
                {
                  "key": "pageNumber",
                  "value": "1"
                },
                {
                  "key": "pageSize",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "Mark Notification as Read",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}",
                "type": "text"
              },
              {
                "key": "x-tenant-id",
                "value": "{{tenantId}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/notifications/1/read",
              "host": ["{{baseUrl}}"],
              "path": ["api", "notifications", "1", "read"]
            }
          }
        }
      ]
    },
    {
      "name": "SignalR Hub",
      "item": [
        {
          "name": "Connect to Notification Hub",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}",
                "type": "text"
              },
              {
                "key": "x-tenant-id",
                "value": "{{tenantId}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/hubs/notifications",
              "host": ["{{baseUrl}}"],
              "path": ["hubs", "notifications"]
            },
            "description": "WebSocket connection endpoint for real-time notifications. Use SignalR client to connect."
          }
        }
      ]
    }
  ]
}
