# Copy this file to .env and fill in real values — never commit .env
# Generate secure random values for all secrets before use.

# ── Docker Hub (used by docker-compose.yml image: refs and docker/build-and-push.mjs) ─
DOCKERHUB_USERNAME=your_dockerhub_username

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_REPLICATION_PASSWORD=your_replication_password_here

# ── PgAdmin ───────────────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=your_pgadmin_password_here

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your_grafana_password_here
