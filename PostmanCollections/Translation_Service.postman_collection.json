{
  "info": {
    "_postman_id": "translation-service-collection",
    "name": "Translation Service API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5006", "type": "string" },
    { "key": "tenantId", "value": "your-tenant-id", "type": "string" },
    { "key": "authToken", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "serviceSecret", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Public",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
          }
        },
        {
          "name": "Health Readiness",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/health/ready", "host": ["{{baseUrl}}"], "path": ["health", "ready"] }
          }
        },
        {
          "name": "Get Translations",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-tenant-id", "value": "{{tenantId}}", "description": "Optional — returns tenant overrides when provided" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/translations/:language",
              "host": ["{{baseUrl}}"],
              "path": ["api", "translations", ":language"],
              "variable": [{ "key": "language", "value": "en" }]
            }
          }
        }
      ]
    },
    {
      "name": "Audit Logs",
      "item": [
        {
          "name": "Get Audit Logs",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "x-tenant-id", "value": "{{tenantId}}", "description": "Optional — OptionalTenantAttribute" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/audit-logs",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "audit-logs"],
              "query": [
                { "key": "tenantId",   "value": "", "disabled": true, "description": "Filter by tenant ID" },
                { "key": "entityType", "value": "", "disabled": true, "description": "Filter by entity type (e.g. User, CategoryEntity)" },
                { "key": "action",     "value": "", "disabled": true, "description": "Filter by action substring (e.g. Deleted, Updated)" },
                { "key": "userId",     "value": "", "disabled": true, "description": "Filter by user who made the change" },
                { "key": "userEmail",  "value": "", "disabled": true, "description": "Filter by user email substring" },
                { "key": "fromDate",   "value": "", "disabled": true, "description": "ISO 8601 UTC start timestamp, e.g. 2026-01-01T00:00:00Z" },
                { "key": "toDate",     "value": "", "disabled": true, "description": "ISO 8601 UTC end timestamp" },
                { "key": "sortBy",     "value": "OccurredAt", "disabled": true, "description": "OccurredAt | Action | EntityType | EntityId | UserId" },
                { "key": "sortDesc",   "value": "true", "disabled": true, "description": "Sort direction (default: true)" },
                { "key": "page",       "value": "1", "disabled": true, "description": "Page number, 1-based (default: 1)" },
                { "key": "pageSize",   "value": "20", "disabled": true, "description": "Items per page, max 100 (default: 20)" }
              ]
            },
            "description": "Returns PaginatedList<AuditLogDto>. Requires Admin or SuperAdmin role."
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Get Translation Keys",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/translations/keys?page=1&pageSize=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "translations", "keys"],
              "query": [{ "key": "page", "value": "1" }, { "key": "pageSize", "value": "20" }]
            }
          }
        },
        {
          "name": "Create Translation Key",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"key\": \"common.save\",\n  \"category\": \"common\",\n  \"description\": \"Save button label\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/translations/keys", "host": ["{{baseUrl}}"], "path": ["api", "translations", "keys"] }
          }
        },
        {
          "name": "Update Translation Key",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Updated description for save button\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/translations/keys/:id", "host": ["{{baseUrl}}"], "path": ["api", "translations", "keys", ":id"], "variable": [{ "key": "id", "value": "1" }] }
          }
        },
        {
          "name": "Delete Translation Key",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/translations/keys/:id", "host": ["{{baseUrl}}"], "path": ["api", "translations", "keys", ":id"], "variable": [{ "key": "id", "value": "1" }] }
          }
        },
        {
          "name": "Toggle Translation Key Archived Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/translations/keys/:id/toggle-archive", "host": ["{{baseUrl}}"], "path": ["api", "translations", "keys", ":id", "toggle-archive"], "variable": [{ "key": "id", "value": "1" }] }
          }
        },
        {
          "name": "Set Translation Value",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"key\": \"common.save\",\n  \"language\": \"en\",\n  \"value\": \"Save\",\n  \"tenantId\": null\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/translations/values", "host": ["{{baseUrl}}"], "path": ["api", "translations", "values"] }
          }
        },
        {
          "name": "Delete Translation Value",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/translations/values/:id", "host": ["{{baseUrl}}"], "path": ["api", "translations", "values", ":id"], "variable": [{ "key": "id", "value": "1" }] }
          }
        },
        {
          "name": "Import Translations",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"language\": \"en\",\n  \"translations\": {\n    \"common.save\": \"Save\",\n    \"common.cancel\": \"Cancel\"\n  },\n  \"tenantId\": null\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/translations/import", "host": ["{{baseUrl}}"], "path": ["api", "translations", "import"] }
          }
        }
      ]
    }
  ]
}
