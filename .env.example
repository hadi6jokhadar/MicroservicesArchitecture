# Copy this file to .env and fill in real values — never commit .env
# Generate secure random values for all secrets before use.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_REPLICATION_PASSWORD=your_replication_password_here

# ── PgAdmin ───────────────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=your_pgadmin_password_here

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your_grafana_password_here

# ── Shared across all .NET services (appsettings.Development.json) ────────────
# JWT secret — must be at least 32 characters, randomly generated
JWT_SECRET=your_jwt_secret_min_32_chars_here

# Service-to-service shared secret — must be at least 64 characters
SERVICE_SHARED_SECRET=your_shared_secret_min_64_chars_here

# ── FileManager — Cloudflare R2 blob storage ──────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_ACCESS_KEY_ID=your_cloudflare_access_key_id
CLOUDFLARE_SECRET_ACCESS_KEY=your_cloudflare_secret_access_key
CLOUDFLARE_BUCKET_NAME=your_bucket_name
CLOUDFLARE_PUBLIC_DOMAIN=https://your-public-domain.r2.dev

# ── FileManager — local paths ─────────────────────────────────────────────────
FFMPEG_PATH=ffmpeg
FILES_SAVE_PATH=C:/FileStorage
