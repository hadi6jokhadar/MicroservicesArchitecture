{
  "info": {
    "_postman_id": "tenant-service-collection",
    "name": "Tenant Service API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5002", "type": "string" },
    { "key": "tenantId", "value": "", "type": "string" },
    { "key": "authToken", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "serviceSecret", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Public",
      "item": [
        {
          "name": "Get Tenant By ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/tenant/:tenantId",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tenant", ":tenantId"],
              "variable": [{ "key": "tenantId", "value": "{{tenantId}}" }]
            }
          }
        }
      ]
    },
    {
      "name": "Authenticated",
      "item": [
        {
          "name": "Get Tenant Config (Service Only)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/tenant/config/:tenantId",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tenant", "config", ":tenantId"],
              "variable": [{ "key": "tenantId", "value": "{{tenantId}}" }]
            }
          }
        },
        {
          "name": "Get All Active Tenants With Config (Service Only)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/tenant/config?page=1&pageSize=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tenant", "config"],
              "query": [{ "key": "page", "value": "1" }, { "key": "pageSize", "value": "20" }]
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Get All Active Tenants",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/tenant/?page=1&pageSize=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "tenant", ""],
              "query": [{ "key": "page", "value": "1" }, { "key": "pageSize", "value": "20" }]
            }
          }
        },
        {
          "name": "Get Tenant By User",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/tenant/user/:userId",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "tenant", "user", ":userId"],
              "variable": [{ "key": "userId", "value": "1" }]
            }
          }
        },
        {
          "name": "Create Tenant",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/tenant/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "tenant", ""]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Acme Corp\",\n  \"identifier\": \"acme\",\n  \"allowedOrigins\": [\"https://app.acme.com\"]\n}"
            }
          }
        },
        {
          "name": "Update Tenant",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/tenant/:tenantId",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "tenant", ":tenantId"],
              "variable": [{ "key": "tenantId", "value": "{{tenantId}}" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Acme Corp Updated\",\n  \"allowedOrigins\": [\"https://app.acme.com\", \"https://admin.acme.com\"]\n}"
            }
          }
        },
        {
          "name": "Delete Tenant",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/tenant/:tenantId",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "tenant", ":tenantId"],
              "variable": [{ "key": "tenantId", "value": "{{tenantId}}" }]
            }
          }
        },
        {
          "name": "Toggle Tenant Archived Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/tenant/:tenantId/toggle-archive",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "tenant", ":tenantId", "toggle-archive"],
              "variable": [{ "key": "tenantId", "value": "{{tenantId}}" }]
            }
          }
        },
        {
          "name": "Get Audit Logs",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/audit-logs?page=1&pageSize=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "audit-logs"],
              "query": [{ "key": "page", "value": "1" }, { "key": "pageSize", "value": "20" }]
            }
          }
        }
      ]
    }
  ]
}
